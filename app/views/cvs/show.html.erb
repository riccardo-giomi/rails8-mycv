<% content_for :title, @cv.base_filename %>

<% content_for :nav_left do %>
  <%= render partial: "layouts/controls/edit", locals: { cv: @cv } %>
<% end %>

<% content_for :nav_right do %>
  <%= render "layouts/controls/download_json", model: @cv %>
  <%= render "layouts/controls/print" %>
  <span class="js-control">
    <%= render "layouts/controls/preview", cv: @cv %>
  </span>
<% end %>

<%= turbo_stream_from @cv %>

<div class="mx-auto my-2">
  <%= render @cv %>
</div>
