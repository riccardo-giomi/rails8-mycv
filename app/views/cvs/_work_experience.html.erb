<div class="mt-2">
  <div class="w-full">
    <%= subform.text_field :title, class: "input-field font-bold font-bold text-xl", placeholder: "Position/title" %>
    <%= subform.text_field :entity, class: "input-field w-full font-bold text-lg text-gray-500", placeholder: "Company/Entity" %>
    <%= subform.text_field :entity_uri, class: "small-input-field italic w-full", placeholder: "URI for company/entity" %>
    <%= subform.text_field :period, class: "input-field font-semibold text-md text-gray-500", placeholder: "Period, e.g. 2000-2010" %>
    <%= subform.text_area  :description, class: "input-field h-auto", placeholder: "Title/job description", rows: 10 %>

    <% if subform.object.has_tags? %>
      <div class="mt-2">
        <% subform.object.tags_array.each do |tag| %>
          <div class="pill"><span><%= tag %></span></div>
        <% end %>
      </div>
    <% end %>
    <%= subform.text_field :tags, class: "small-input-field italic w-full", placeholder: "e.g. Ruby,Ruby on Rails,PostgreSQL" %>
  </div>

  <div class="flex gap-2">
    <%= form.button id: "delete-work-experience-button", name: "delete_work_experience", value: subform.object.id, class: "button button-red my-1", data: { turbo_confirm: "Are you sure?" } do %>
      <svg class="size-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
      </svg>
    <% end %>

    <% if index > 0 %>
      <%= form.button id: "move-work-experience-up-button", name: "move_work_experience_up", value: subform.object.id, class: "button my-1" do %>
        <svg class="size-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5 12 3m0 0 7.5 7.5M12 3v18" />
        </svg>
      <% end %>
    <% end %>
    <% if index < (count - 1) %>
      <%= form.button id: "move-work-experience-down-button", name: "move_work_experience_down", value: subform.object.id, class: "button my-1" do %>
        <svg class="size-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3" />
        </svg>
      <% end %>
    <% end %>
  </div>

  <% if index < (count - 1) %>
    <div class="w-full my-1 border-2 border-dotted border-gray-400 p-2 flex gap-2">
      <%= page_break_checkbox(@cv, "after_work_experience", position: index, class: "checkbox") %>
      <span class="italic font-medium">Insert Page Break Here</span>
    </div>
  <% end %>
</div>

